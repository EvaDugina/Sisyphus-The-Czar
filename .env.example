# false — production hardening; true — подробные dev-логи и послабление Origin.
DEBUG=false

# Публичный origin без завершающего слеша. Несколько значений — через запятую.
# Если пусто, сервер принимает только Origin с тем же Host.
ALLOWED_ORIGIN=https://example.com

# Сколько секунд сессия хранится после последней активности.
SESSION_TTL_SECONDS=86400
